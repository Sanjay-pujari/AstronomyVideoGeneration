ASPNETCORE_ENVIRONMENT=Development
DOTNET_ENVIRONMENT=Development
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=astronomy_media_factory;Username=postgres;Password=postgres

Rendering__FfmpegPath=ffmpeg
Rendering__WorkingDirectory=./media-output
Rendering__VideoWidth=1920
Rendering__VideoHeight=1080
Rendering__FrameRate=30

AstronomyApis__NasaApiKey=DEMO_KEY
AstronomyApis__NasaBaseUrl=https://api.nasa.gov
AstronomyApis__MpcBaseUrl=https://www.minorplanetcenter.net
AstronomyApis__SkyfieldServiceUrl=http://localhost:8099
AstronomyApis__StellariumScriptsDirectory=./stellarium-scripts

AzureOpenAI__Endpoint=https://your-openai-resource.openai.azure.com/
AzureOpenAI__ApiKey=replace-me
AzureOpenAI__ChatDeployment=gpt-4o-mini
AzureOpenAI__UseManagedIdentity=false

AzureSpeech__Key=replace-me
AzureSpeech__Region=eastus
AzureSpeech__Endpoint=
AzureSpeech__UseManagedIdentity=false
AzureSpeech__Voice=en-US-FableMultilingualNeural

AzureBlob__ConnectionString=UseDevelopmentStorage=true
AzureBlob__ContainerName=astronomy-media
AzureBlob__UseManagedIdentity=false
AzureBlob__AccountName=
AzureBlob__ServiceUri=

YouTube__PublishingEnabled=false
YouTube__ClientId=replace-me
YouTube__ClientSecret=replace-me
YouTube__PrivacyStatus=private
YouTube__RefreshToken=
YouTube__TokenFilePath=

SkyfieldSidecar__Enabled=true
SkyfieldSidecar__BaseUrl=http://localhost:8010

Telemetry__ApplicationInsightsConnectionString=
KeyVault__VaultUri=
