{
  "Rendering": {
    "FfmpegSegmentTimeoutSeconds": 120,
    "WriteSegmentDiagnostics": true,
    "FfmpegTimeoutSeconds": 600,
    "KeepIntermediateFiles": true,
    "FfprobePath": "D:\\AstronomyWorkspace\\ffmpeg\\bin\\ffprobe.exe",
    "EnableTransitions": true,
    "TransitionDurationSeconds": 0.5,
    "TransitionType": "fade",
    "EnableFadeInOut": true,
    "FadeDurationSeconds": 0.75,
    "ShortFadeDurationSeconds": 0.4,
    "EnableKenBurns": true,
    "KenBurnsFps": 30,
    "KenBurnsZoomStart": 1.0,
    "KenBurnsZoomEnd": 1.1,
    "ShortKenBurnsZoomEnd": 1.08,
    "KenBurnsUseEasing": true,
    "EnableDirectionalMotion": false,
    "SegmentRenderTimeoutSeconds": 180,
    "FinalLongRenderTimeoutSeconds": 900,
    "FinalShortRenderTimeoutSeconds": 300,
    "FinalMetaRenderTimeoutSeconds": 300
  },
  "StartupValidation": {
    "RequireAzureOpenAi": true,
    "RequireAzureSpeech": true,
    "RequireBlobStorage": true
  },
  "YouTube": {
    "ClientId": "",
    "ClientSecret": "",
    "RedirectUri": "http://localhost:5005/api/youtubeoauth/callback",
    "ApplicationName": "AstronomyVideoGeneration",
    "ExpectedChannelTitle": "",
    "ExpectedChannelId": "",
    "PublishingEnabled": false,
    "UploadThumbnailForLongVideos": true,
    "UploadCustomThumbnailForShorts": true,
    "MaxThumbnailSizeBytes": 2097152,
    "CompressThumbnailIfTooLarge": true,
    "ThumbnailJpegQuality": 85
  },
  "Meta": {
    "AppId": "",
    "AppSecret": "",
    "RedirectUri": "https://localhost:59235/api/metaoauth/callback",
    "ExpectedFacebookPageName": "",
    "ExpectedFacebookPageId": "",
    "ExpectedInstagramUsername": "",
    "Scopes": [
      "pages_manage_posts",
      "pages_read_engagement",
      "pages_show_list",
      "instagram_basic",
      "instagram_content_publish",
      "business_management"
    ]
  },
  "ContentDuration": {
    "DailySkyGuideMinutes": 6,
    "SpecialEventGuideMinutes": 8,
    "YouTubeShortSeconds": 50,
    "InstagramReelSeconds": 40,
    "FacebookReelSeconds": 50,
    "AllowDynamicOptimization": true
  },
  "ContentExpansion": {
    "Enabled": true,
    "TargetDailyGuideMinutes": 6,
    "TargetSpecialEventMinutes": 8,
    "MinObjectsPerGuide": 3,
    "MaxObjectsPerGuide": 6,
    "AllowMoonSegment": true,
    "AllowConstellations": true,
    "AllowBrightStars": true,
    "AllowDeepSkyObjects": true,
    "AllowObservationTips": true,
    "MinimumVisibilityScore": 0.55
  },
  "ThumbnailGeneration": {
    "Enabled": true,
    "Mode": "LocalAssetCollage",
    "AssetRootPath": "assets/celestial",
    "PreferredAssetFileNames": [
      "hero-transparent.png",
      "hero.png",
      "cinematic.png",
      "closeup.png"
    ],
    "PreferPngAssets": true,
    "PreferAssetPackImages": true,
    "DeepSpaceHeroPenalty": 0.45,
    "LongThumbnailWidth": 1280,
    "LongThumbnailHeight": 720,
    "ShortThumbnailWidth": 1080,
    "ShortThumbnailHeight": 1920,
    "MaxSupportObjectsLong": 2,
    "MaxSupportObjectsShort": 1,
    "EnableStellariumBackground": true,
    "FallbackToStellariumFrame": true,
    "EnableHookText": true,
    "MaxHookWords": 4,
    "EnableBranding": true,
    "BrandText": "AstroPulse",
    "JpegQuality": 85,
    "MaxFileSizeBytes": 2097152
  },
  "CelestialAssetPack": {
    "Enabled": true,
    "SourceSheetPath": "assets/celestial/source/celestial-object-sheet.png",
    "SheetMapPath": "assets/celestial/source/celestial-object-sheet-map.json",
    "OutputRootPath": "assets/celestial",
    "OverwriteExisting": false
  },
  "VideoEncoding": {
    "YouTubeLongQualityMode": "Balanced",
    "YouTubeLongPreset": "fast",
    "YouTubeLongCrf": 19,
    "YouTubeLongMaxRate": "20M",
    "YouTubeLongBufferSize": "40M"
  }
}
