{
  "Publishing": {
    "Enabled": true,
    "Mode": "Private",
    "DefaultPrivacyStatus": "private",
    "UploadThumbnail": true,
    "RequirePrePublishValidation": true,
    "PublishLongVideo": true,
    "PublishShortVideo": true
  },
  "PublishingValidation": {
    "Enabled": true,
    "MinimumLongVideoDurationSeconds": 60,
    "MinimumShortVideoDurationSeconds": 15,
    "BlockPublishOnWarning": false
  },
  "Rendering": {
    "FfmpegSegmentTimeoutSeconds": 180,
    "FfmpegTimeoutSeconds": 600,
    "KeepIntermediateFiles": true,
    "FfprobePath": "D:\\AstronomyWorkspace\\ffmpeg\\bin\\ffprobe.exe",
    "EnableTransitions": true,
    "TransitionDurationSeconds": 0.5,
    "TransitionType": "fade"
  },
  "StartupValidation": {
    "RequireAzureOpenAi": true,
    "RequireAzureSpeech": true,
    "RequireBlobStorage": true
  },
  "SkyfieldSidecar": {
    "Enabled": true,
    "BaseUrl": "http://localhost:8010"
  },
  "YouTube": {
    "ClientId": "",
    "ClientSecret": "",
    "RedirectUri": "http://localhost:5005/api/youtubeoauth/callback",
    "ApplicationName": "AstronomyVideoGeneration",
    "ExpectedChannelTitle": "",
    "ExpectedChannelId": "",
    "PublishingEnabled": false,
    "UploadThumbnailForLongVideos": true,
    "UploadThumbnailForShorts": false
  },
  "Meta": {
    "AppId": "",
    "AppSecret": "",
    "RedirectUri": "https://localhost:59235/api/metaoauth/callback",
    "ExpectedFacebookPageName": "",
    "ExpectedFacebookPageId": "",
    "ExpectedInstagramUsername": "",
    "PublishFacebook": true,
    "PublishInstagram": true,
    "Scopes": [
      "pages_manage_posts",
      "pages_read_engagement",
      "pages_show_list",
      "instagram_basic",
      "instagram_content_publish",
      "business_management"
    ]
  },
  "Thumbnail": {
    "Enabled": true,
    "Width": 1280,
    "Height": 720
  },
  "MetaPublishing": {
    "Enabled": false,
    "PublishFacebookReel": true,
    "PublishInstagramReel": false,
    "Mode": "DryRun",
    "FacebookPageId": "",
    "CaptionHashtagSuffix": "#Astronomy #NightSky #Stargazing",
    "FacebookReelProcessingPollSeconds": 10,
    "FacebookReelProcessingMaxAttempts": 12,
    "RequirePublishedState": true
  }
}
