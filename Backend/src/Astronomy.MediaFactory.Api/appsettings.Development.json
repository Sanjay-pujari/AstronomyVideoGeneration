{
  "Publishing": {
    "Enabled": true,
    "Mode": "Private",
    "DefaultPrivacyStatus": "private",
    "UploadThumbnail": true,
    "RequirePrePublishValidation": true,
    "PublishLongVideo": true,
    "PublishShortVideo": true
  },
  "PublishingValidation": {
    "Enabled": true,
    "MinimumLongVideoDurationSeconds": 60,
    "MinimumShortVideoDurationSeconds": 15,
    "BlockPublishOnWarning": false
  },
  "Rendering": {
    "FfmpegSegmentTimeoutSeconds": 180,
    "FfmpegTimeoutSeconds": 600,
    "KeepIntermediateFiles": true,
    "FfprobePath": "D:\\AstronomyWorkspace\\ffmpeg\\bin\\ffprobe.exe",
    "EnableTransitions": true,
    "TransitionDurationSeconds": 0.5,
    "TransitionType": "fade"
  },
  "StartupValidation": {
    "RequireAzureOpenAi": true,
    "RequireAzureSpeech": true,
    "RequireBlobStorage": true
  },
  "SkyfieldSidecar": {
    "Enabled": true,
    "BaseUrl": "http://localhost:8010"
  },
  "YouTube": {
    "ClientId": "",
    "ClientSecret": "",
    "RedirectUri": "http://localhost:5005/api/youtubeoauth/callback",
    "ApplicationName": "AstronomyVideoGeneration",
    "ExpectedChannelTitle": "",
    "ExpectedChannelId": "",
    "PublishingEnabled": false,
    "UploadThumbnailForLongVideos": true,
    "UploadThumbnailForShorts": false
  },
  "Meta": {
    "AppId": "",
    "AppSecret": "",
    "RedirectUri": "https://localhost:59235/api/metaoauth/callback",
    "ExpectedFacebookPageName": "",
    "ExpectedFacebookPageId": "",
    "ExpectedInstagramUsername": "",
    "PublishFacebook": true,
    "PublishInstagram": true,
    "Scopes": [
      "pages_manage_posts",
      "pages_read_engagement",
      "pages_show_list",
      "instagram_basic",
      "instagram_content_publish",
      "business_management"
    ]
  },
  "Thumbnail": {
    "Enabled": true,
    "Width": 1280,
    "Height": 720
  },
  "MetaPublishing": {
    "Enabled": true,
    "PublishFacebookReel": true,
    "PublishInstagramReel": true,
    "Mode": "DryRun",
    "FacebookPageId": "",
    "CaptionHashtagSuffix": "#Astronomy #NightSky #Stargazing",
    "FacebookReelProcessingPollSeconds": 10,
    "FacebookReelProcessingMaxAttempts": 12,
    "RequirePublishedState": true,
    "PublishFacebookFullVideo": false,
    "PublishInstagramFullVideo": false,
    "InstagramContainerPollSeconds": 10,
    "InstagramContainerMaxAttempts": 18,
    "PublicMediaBaseUrl": "",
    "PublicMediaUploadEnabled": false
  },
  "PublicMediaStorage": {
    "Enabled": true,
    "Provider": "AzureBlob",
    "ConnectionString": "",
    "ContainerName": "meta-media",
    "BlobPrefix": "astronomy/reels",
    "UseSasUrl": true,
    "SasExpiryHours": 24,
    "PublicBaseUrl": ""
  },
  "TokenHealth": {
    "Enabled": true,
    "CheckOnStartup": true,
    "CheckBeforePublish": true,
    "RefreshBeforeExpiryDays": 7,
    "WriteHealthReport": true
  },
  "Analytics": {
    "Enabled": true,
    "CollectEveryMinutes": 60,
    "CollectForRecentDays": 14
  },
  "Optimization": {
    "Enabled": true,
    "Mode": "RecommendOnly",
    "MinimumDataPoints": 10,
    "ApplyToSchedulerRunsOnly": true,
    "AllowTitleOptimization": true,
    "AllowThumbnailOptimization": true,
    "AllowDurationOptimization": true,
    "AllowPublishTimeOptimization": true,
    "AllowObjectRankingOptimization": true,
    "ConfidenceThreshold": 0.6
  },
  "AIOptimization": {
    "Enabled": true,
    "Mode": "RecommendOnly",
    "UseAzureOpenAI": true,
    "MinimumAnalyticsRows": 20,
    "OutputFileName": "ai-optimization-recommendations.json"
  }
}
