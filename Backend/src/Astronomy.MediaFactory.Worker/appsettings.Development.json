{
  "Publishing": {
    "Enabled": true,
    "Mode": "Private",
    "DefaultPrivacyStatus": "private",
    "UploadThumbnail": true,
    "RequirePrePublishValidation": true,
    "PublishLongVideo": true,
    "PublishShortVideo": true
  },
  "PublishingValidation": {
    "Enabled": true,
    "MinimumLongVideoDurationSeconds": 60,
    "MinimumShortVideoDurationSeconds": 15,
    "BlockPublishOnWarning": false
  },
  "Rendering": {
    "FfmpegSegmentTimeoutSeconds": 180,
    "FfmpegTimeoutSeconds": 600,
    "KeepIntermediateFiles": true,
    "FfprobePath": "D:\\AstronomyWorkspace\\ffmpeg\\bin\\ffprobe.exe",
    "EnableTransitions": true,
    "TransitionDurationSeconds": 0.5,
    "TransitionType": "fade"
  },
  "StartupValidation": {
    "RequireAzureOpenAi": false,
    "RequireAzureSpeech": false,
    "RequireBlobStorage": false,
    "RequireYouTubeWhenPublishingEnabled": false,
    "RequireSkyfieldWhenEnabled": false
  },
  "Operations": {
    "EnforceProductionValidation": false
  },
  "Thumbnail": {
    "Enabled": true,
    "Width": 1280,
    "Height": 720
  },
  "YouTube": {
    "ClientId": "",
    "ClientSecret": "",
    "RedirectUri": "http://localhost:5005/api/youtubeoauth/callback",
    "ApplicationName": "AstronomyVideoGeneration",
    "ExpectedChannelTitle": "",
    "ExpectedChannelId": "",
    "UploadThumbnailForLongVideos": true,
    "UploadThumbnailForShorts": false
  },
  "TokenHealth": {
    "Enabled": true,
    "CheckOnStartup": true,
    "CheckBeforePublish": true,
    "RefreshBeforeExpiryDays": 7,
    "WriteHealthReport": true
  },
  "Analytics": {
    "Enabled": true,
    "CollectEveryMinutes": 60,
    "CollectForRecentDays": 14
  }
}
