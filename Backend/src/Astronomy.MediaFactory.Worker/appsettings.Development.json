{
  "Rendering": {
    "FfmpegSegmentTimeoutSeconds": 180,
    "FfmpegTimeoutSeconds": 600,
    "KeepIntermediateFiles": true,
    "FfprobePath": "D:\\AstronomyWorkspace\\ffmpeg\\bin\\ffprobe.exe",
    "EnableTransitions": true,
    "TransitionDurationSeconds": 0.5,
    "TransitionType": "fade"
  },
  "StartupValidation": {
    "RequireAzureOpenAi": false,
    "RequireAzureSpeech": false,
    "RequireBlobStorage": false,
    "RequireYouTubeWhenPublishingEnabled": false,
    "RequireSkyfieldWhenEnabled": false
  },
  "Operations": {
    "EnforceProductionValidation": false
  },
  "YouTube": {
    "ClientId": "",
    "ClientSecret": "",
    "RedirectUri": "http://localhost:5005/api/youtubeoauth/callback",
    "ApplicationName": "AstronomyVideoGeneration",
    "ExpectedChannelTitle": "",
    "ExpectedChannelId": "",
    "UploadThumbnailForLongVideos": true,
    "UploadThumbnailForShorts": false,
    "MaxThumbnailSizeBytes": 2097152,
    "CompressThumbnailIfTooLarge": true,
    "ThumbnailJpegQuality": 85
  },
  "ContentDuration": {
    "DailySkyGuideMinutes": 6,
    "SpecialEventGuideMinutes": 8,
    "YouTubeShortSeconds": 50,
    "InstagramReelSeconds": 40,
    "FacebookReelSeconds": 50,
    "AllowDynamicOptimization": true
  },
  "ContentExpansion": {
    "Enabled": true,
    "TargetDailyGuideMinutes": 6,
    "TargetSpecialEventMinutes": 8,
    "MinObjectsPerGuide": 3,
    "MaxObjectsPerGuide": 6,
    "AllowMoonSegment": true,
    "AllowConstellations": true,
    "AllowBrightStars": true,
    "AllowDeepSkyObjects": true,
    "AllowObservationTips": true,
    "MinimumVisibilityScore": 0.55
  },
  "ThumbnailAIOptimization": {
    "Enabled": true,
    "UseAzureOpenAI": true,
    "EnableHookOptimization": true,
    "EnableEmotionOptimization": true,
    "EnableCTRScoring": true,
    "MaxHookWords": 5,
    "MinimumConfidence": 0.7,
    "PreventScientificHallucinations": true,
    "AllowedEmotions": [
      "wonder",
      "urgency",
      "curiosity",
      "discovery",
      "rarity"
    ],
    "DisallowedPatterns": [
      "fake",
      "alien",
      "ufo",
      "apocalypse",
      "clickbait"
    ],
    "OutputFileName": "thumbnail-ai-optimization.json"
  },
  "ThumbnailCinematicAI": {
    "Enabled": true,
    "EnableSmartCropping": true,
    "EnableObjectFocusEnhancement": true,
    "EnableColorMoodGrading": true,
    "EnableVisualHierarchyOptimization": true,
    "EnablePlanetMoonEnhancement": true,
    "EnableConjunctionFraming": true,
    "EnablePortraitSafeCropping": true,
    "AllowedMoodProfiles": [
      "dramatic",
      "moonlight",
      "deepSpace",
      "sunset",
      "cinematicBlue",
      "warmGlow"
    ],
    "PreventFakeAstronomy": true,
    "MaximumObjectScaleBoost": 1.30,
    "OutputFileName": "thumbnail-cinematic-ai-report.json"
  }
}
