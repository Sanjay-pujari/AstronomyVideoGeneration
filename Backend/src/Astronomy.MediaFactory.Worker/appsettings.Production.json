{
  "StartupValidation": {
    "RequireAzureOpenAi": true,
    "RequireAzureSpeech": true,
    "RequireBlobStorage": true,
    "RequireYouTubeWhenPublishingEnabled": true,
    "RequireSkyfieldWhenEnabled": true
  },
  "Publishing": {
    "Enabled": true,
    "Mode": "Private",
    "PublishLongVideo": true,
    "PublishShortVideo": true,
    "DefaultPrivacyStatus": "private"
  },
  "YouTube": {
    "UploadThumbnailForLongVideos": true,
    "UploadThumbnailForShorts": false
  },
  "TokenHealth": {
    "Enabled": true,
    "CheckOnStartup": true,
    "CheckBeforePublish": true,
    "RefreshBeforeExpiryDays": 7,
    "WriteHealthReport": true
  },
  "Analytics": {
    "Enabled": true,
    "CollectEveryMinutes": 60,
    "CollectForRecentDays": 14
  },
  "Optimization": {
    "Enabled": true,
    "Mode": "RecommendOnly",
    "MinimumDataPoints": 10,
    "ApplyToSchedulerRunsOnly": true,
    "AllowTitleOptimization": true,
    "AllowThumbnailOptimization": true,
    "AllowDurationOptimization": true,
    "AllowPublishTimeOptimization": true,
    "AllowObjectRankingOptimization": true,
    "ConfidenceThreshold": 0.6
  },
  "AstronomyEvents": {
    "Enabled": true,
    "LookAheadDays": 30,
    "MinimumContentOpportunityScore": 0.65,
    "Sources": {
      "MeteorShowers": true,
      "MoonPhases": true,
      "PlanetaryConjunctions": true,
      "Eclipses": true,
      "Comets": false,
      "IssPasses": false
    }
  }
}
