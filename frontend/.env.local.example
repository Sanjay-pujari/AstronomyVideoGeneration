# Local operator overrides for the AstroPulse dashboard.
# If you serve this static frontend without Vite, set window.ASTROPULSE_API_BASE_URL
# in the hosting page or reverse-proxy /api to the backend.
VITE_API_BASE_URL=http://localhost:8080
VITE_API_TIMEOUT_MS=12000

# Production API base URL example.
VITE_PRODUCTION_API_BASE_URL=https://api.astropulse.example
