# Local development API base URL
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080

# Production API base URL placeholder; replace during deployment.
# EXPO_PUBLIC_API_BASE_URL=https://api.astropulse.example

# Development-only mock mode. The app disables mock mode automatically when NODE_ENV=production.
EXPO_PUBLIC_MOCK_MODE=false

# Central API client timeout in milliseconds.
EXPO_PUBLIC_API_TIMEOUT_MS=10000
